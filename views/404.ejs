<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error 404 - Starkit</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md text-center">
        <!-- Error Card -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
            <!-- Error Code -->
            <h1 class="text-6xl font-bold text-gray-900 mb-4">404</h1>

            <!-- Error Title -->
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Página No Encontrada</h2>

            <!-- Error Description -->
            <p class="text-gray-600 mb-6">La página que buscas no existe o ha sido movida.</p>

            <!-- Return Link -->
            <a href="/auth/login" class="inline-block bg-gray-900 text-white font-medium py-2.5 px-6 rounded-lg hover:bg-gray-800 transition duration-200">
                Volver al login
            </a>
        </div>
    </div>
</body>
</html>
