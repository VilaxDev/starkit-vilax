<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Usuario - Starkit</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <div class="flex h-screen">
        <!-- Sidebar -->
        <div class="w-64 bg-gray-900 text-white p-6 overflow-y-auto">
            <!-- Logo -->
            <div class="flex items-center mb-8 pb-6 border-b border-gray-700">
                <div class="inline-flex items-center justify-center h-10 w-10 rounded-md bg-blue-600">
                    <i class="fas fa-rocket"></i>
                </div>
                <span class="ml-3 text-2xl font-bold">Starkit</span>
            </div>

            <!-- Navigation -->
            <nav class="space-y-2">
                <a href="/admin/dashboard" class="flex items-center px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 transition">
                    <i class="fas fa-chart-line mr-3"></i>Dashboard
                </a>
                <a href="/admin/profile" class="flex items-center px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 transition">
                    <i class="fas fa-user-circle mr-3"></i>Mi Perfil
                </a>
                <a href="/admin/users" class="flex items-center px-4 py-3 rounded-lg bg-blue-600 text-white font-medium">
                    <i class="fas fa-users mr-3"></i>Usuarios
                </a>
            </nav>

            <!-- Logout -->
            <div class="mt-auto pt-6 border-t border-gray-700">
                <a href="/auth/logout" class="flex items-center px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 transition w-full">
                    <i class="fas fa-sign-out-alt mr-3"></i>Cerrar Sesión
                </a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="flex-1 overflow-auto">
            <!-- Top Bar -->
            <div class="bg-white shadow-sm border-b border-gray-200 p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-3xl font-bold text-gray-900">Editar Usuario</h1>
                        <p class="text-gray-600 mt-1">
                            <a href="/admin/users" class="text-blue-600 hover:text-blue-700">← Volver a Usuarios</a>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Edit User Content -->
            <div class="p-6">
                <!-- Error Message -->
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg flex items-center">
                        <i class="fas fa-exclamation-circle text-red-600 mr-3"></i>
                        <p class="text-red-700 text-sm"><%= error %></p>
                    </div>
                <% } %>

                <!-- Edit Form -->
                <div class="max-w-2xl">
                    <div class="bg-white rounded-lg shadow p-6">
                        <!-- User Avatar -->
                        <div class="flex justify-center mb-6">
                            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
                                <i class="fas fa-user text-4xl text-white"></i>
                            </div>
                        </div>

                        <form method="POST" class="space-y-4">
                            <!-- Full Name -->
                            <div>
                                <label for="fullname" class="block text-sm font-medium text-gray-700 mb-2">
                                    <i class="fas fa-user mr-2"></i>Nombre Completo
                                </label>
                                <input 
                                    type="text" 
                                    id="fullname" 
                                    name="fullname" 
                                    required 
                                    value="Juan Pérez"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
                                >
                            </div>

                            <!-- Email -->
                            <div>
                                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                                    <i class="fas fa-envelope mr-2"></i>Correo Electrónico
                                </label>
                                <input 
                                    type="email" 
                                    id="email" 
                                    name="email" 
                                    required 
                                    value="juan@example.com"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
                                >
                            </div>

                            <!-- Phone -->
                            <div>
                                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                                    <i class="fas fa-phone mr-2"></i>Teléfono
                                </label>
                                <input 
                                    type="tel" 
                                    id="phone" 
                                    name="phone" 
                                    required 
                                    value="+1 (555) 123-4567"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
                                >
                            </div>

                            <!-- Password (Optional) -->
                            <div>
                                <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
                                    <i class="fas fa-lock mr-2"></i>Nueva Contraseña (Dejar en blanco para no cambiar)
                                </label>
                                <input 
                                    type="password" 
                                    id="password" 
                                    name="password" 
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
                                    placeholder="••••••••"
                                >
                            </div>

                            <!-- Buttons -->
                            <div class="flex gap-3 pt-6 border-t border-gray-200 mt-6">
                                <button 
                                    type="submit" 
                                    class="flex-1 bg-blue-600 text-white font-semibold py-3 rounded-lg hover:bg-blue-700 transition duration-200 flex items-center justify-center"
                                >
                                    <i class="fas fa-save mr-2"></i>Guardar Cambios
                                </button>
                                <a href="/admin/users" class="flex-1 bg-gray-300 text-gray-700 font-semibold py-3 rounded-lg hover:bg-gray-400 transition duration-200 flex items-center justify-center">
                                    <i class="fas fa-times mr-2"></i>Cancelar
                                </a>
                            </div>
                        </form>

                        <!-- Danger Zone -->
                        <div class="mt-8 p-6 border-2 border-red-200 rounded-lg bg-red-50">
                            <h3 class="text-lg font-bold text-red-900 mb-2">
                                <i class="fas fa-exclamation-triangle mr-2"></i>Zona de Peligro
                            </h3>
                            <p class="text-red-700 text-sm mb-4">
                                Eliminar este usuario es una acción permanente y no se puede deshacer.
                            </p>
                            <form method="POST" action="/auth/delete-user/<%= user.id || '1' %>" style="display: inline;">
                                <button 
                                    type="submit" 
                                    onclick="return confirm('¿Estás seguro de que quieres eliminar este usuario permanentemente?')"
                                    class="px-6 py-3 bg-red-600 text-white font-semibold rounded-lg hover:bg-red-700 transition duration-200"
                                >
                                    <i class="fas fa-trash-alt mr-2"></i>Eliminar Usuario
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
